      res[r.abbr] = { wouldWin: wW, electoralVotes: eV, currentVoteShare: cV, newVoteShare: nTV, projectedMargin: wW ? nM : 0, newWinner: nRes[0].candidate, newResults: nRes, swing: nTV - cV };
