      let dem = 0, rep = 0, trd = 0;
      d[n].results.forEach(c => { const p = c.party.toLowerCase(); if (p.includes('dem')) dem += c.pct; else if (p.includes('rep')) rep += c.pct; else trd += c.pct; });
