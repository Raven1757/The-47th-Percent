      const rem = 1 - nTV;
      const nRes = r.result.map(x => x.candidate === c.pk ? { ...x, percent: nTV } : { ...x, percent: rem * (oT > 0 ? x.percent / oT : 0) }).sort((a, b) => b.percent - a.percent);
