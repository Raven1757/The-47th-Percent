            if (isFinal && ct.final_overall_results) {
                let totalPV = 0;
                const res = ct.final_overall_results;
                for (let i = 0; i < res.length; i++) totalPV += (res[i].popular_votes || 0);
                for (let i = 0; i < res.length; i++) {
                    let c = res[i];
